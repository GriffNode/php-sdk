{
    "version": "0.1.0",
    "description": "Official GriffNode SDK. Non-custodial crypto payment gateway: accept BTC, ETH, LTC, DOGE, DASH and ERC-20 tokens straight to your own wallet.",
    "keywords": [
        "griffnode",
        "crypto",
        "payments",
        "bitcoin",
        "ethereum",
        "payment-gateway",
        "non-custodial",
        "sdk"
    ],
    "homepage": "https://griffnode.com",
    "license": "Apache-2.0",
    "authors": [
        {
            "name": "GriffNode",
            "homepage": "https://griffnode.com",
            "email": "dev@griffnode.com"
        }
    ],
    "require": {
        "php": "^7.4 || ^8.0",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "guzzlehttp/guzzle": "^7.3",
        "guzzlehttp/psr7": "^1.7 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^8.0 || ^9.0",
        "friendsofphp/php-cs-fixer": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "GriffNode\\": "lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GriffNode\\Test\\": "test/"
        }
    },
    "name": "griffnode/php-sdk",
    "support": {
        "issues": "https://github.com/GriffNode/php-sdk/issues",
        "source": "https://github.com/GriffNode/php-sdk",
        "docs": "https://docs.griffnode.com/reference"
    }
}